<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="edition-pages-1-schema" author="science-alive">
        <addColumn tableName="SA_EDITION">
            <column name="POSTER_IMAGE" type="varchar(255)"/>
        </addColumn>

        <createTable tableName="SA_TALK">
            <column name="ID" type="${uuid.type}"><constraints primaryKey="true" nullable="false"/></column>
            <column name="VERSION" type="int"><constraints nullable="false"/></column>
            <column name="EDITION_NO" type="int"/>
            <column name="TITLE" type="varchar(500)"/>
            <column name="SPEAKER_NAME" type="varchar(255)"/>
            <column name="SPEAKER_ROLE" type="varchar(255)"/>
            <column name="TIME_SLOT" type="varchar(64)"/>
            <column name="SORT_ORDER" type="int"/>
        </createTable>

        <createTable tableName="SA_ARTICLE">
            <column name="ID" type="${uuid.type}"><constraints primaryKey="true" nullable="false"/></column>
            <column name="VERSION" type="int"><constraints nullable="false"/></column>
            <column name="EDITION_NO" type="int"/>
            <column name="TITLE" type="varchar(500)"/>
            <column name="PUBLISHER" type="varchar(255)"/>
            <column name="PUBLISHED_DATE" type="varchar(32)"/>
            <column name="URL" type="varchar(512)"/>
            <column name="SORT_ORDER" type="int"/>
        </createTable>
    </changeSet>

    <changeSet id="edition-pages-2-posters" author="science-alive">
        <update tableName="SA_EDITION"><column name="POSTER_IMAGE" value="linear-gradient(160deg,#0b1b3a,#0a0f1f)"/><where>EDITION_NO = 7</where></update>
        <update tableName="SA_EDITION"><column name="POSTER_IMAGE" value="linear-gradient(160deg,#1a1030,#0c0a1a)"/><where>EDITION_NO = 6</where></update>
        <update tableName="SA_EDITION"><column name="POSTER_IMAGE" value="linear-gradient(160deg,#0e2a24,#08130f)"/><where>EDITION_NO = 5</where></update>
        <update tableName="SA_EDITION"><column name="POSTER_IMAGE" value="linear-gradient(160deg,#2a1a10,#140c07)"/><where>EDITION_NO = 4</where></update>
    </changeSet>

