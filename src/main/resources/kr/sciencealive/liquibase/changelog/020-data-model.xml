<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="data-1" author="science-alive">
        <createTable tableName="SA_EDITION">
            <column name="ID" type="${uuid.type}"><constraints primaryKey="true" nullable="false"/></column>
            <column name="VERSION" type="int"><constraints nullable="false"/></column>
            <column name="EDITION_NO" type="int"/>
            <column name="YEAR_" type="int"/>
            <column name="THEME" type="varchar(255)"/>
            <column name="EVENT_DATE" type="varchar(64)"/>
            <column name="VENUE" type="varchar(255)"/>
            <column name="TALKS" type="int"/>
            <column name="STATUS" type="varchar(32)"/>
        </createTable>

        <createTable tableName="SA_SPEAKER">
            <column name="ID" type="${uuid.type}"><constraints primaryKey="true" nullable="false"/></column>
            <column name="VERSION" type="int"><constraints nullable="false"/></column>
            <column name="NAME" type="varchar(255)"/>
            <column name="ROLE_" type="varchar(255)"/>
            <column name="TOPIC" type="varchar(500)"/>
            <column name="SORT_ORDER" type="int"/>
        </createTable>

        <createTable tableName="SA_SUBMISSION">
            <column name="ID" type="${uuid.type}"><constraints primaryKey="true" nullable="false"/></column>
            <column name="VERSION" type="int"><constraints nullable="false"/></column>
            <column name="CODE" type="varchar(32)"/>
            <column name="TITLE" type="varchar(500)"/>
            <column name="ORG" type="varchar(255)"/>
            <column name="DIVISION" type="varchar(32)"/>
            <column name="EDITION_NO" type="int"/>
            <column name="AWARD" type="varchar(32)"/>
            <column name="VIEWS" type="int"/>
            <column name="IMAGE_GRADIENT" type="varchar(255)"/>
        </createTable>
    </changeSet>

